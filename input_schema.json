{
  "description": "Worker Input Editor Test Demo. This Worker demonstrates all 11 supported input editor types: input, textarea, number, select, radio, checkbox, switch, datepicker, requestList, requestListSource, and stringList.",
  "b": "urls",
  "properties": [
    {
      "title": "URL List (requestList)",
      "name": "urls",
      "type": "array",
      "editor": "requestList",
      "description": "Batch input for page links to scrape",
      "default": [
        {
          "url": "https://example.com/page1"
        },
        {
          "url": "https://example.com/page2"
        }
      ],
      "required": true
    },
    {
      "title": "URL Source (requestListSource)",
      "name": "sources",
      "type": "array",
      "editor": "requestListSource",
      "description": "URL request source with extra parameters",
      "default": [
        {
          "url": "https://example.com/source1",
          "num_of_posts": "10"
        }
      ],
      "param_list": [
        {
          "param": "url",
          "title": "URL",
          "required": true,
          "description": "The URL to scrape"
        },
        {
          "param": "num_of_posts",
          "title": "Maximum Posts",
          "description": "Maximum number of posts to fetch"
        }
      ]
    },
    {
      "title": "Search Terms (stringList)",
      "name": "searchTerms",
      "type": "array",
      "editor": "stringList",
      "description": "Batch input for multiple keywords",
      "default": [
        {
          "string": "restaurant"
        },
        {
          "string": "cafe"
        }
      ]
    },
    {
      "title": "Location (input)",
      "name": "location",
      "type": "string",
      "editor": "input",
      "description": "Short text input example",
      "default": "New York, USA"
    },
    {
      "title": "Notes (textarea)",
      "name": "notes",
      "type": "string",
      "editor": "textarea",
      "description": "Multi-line text input example"
    },
    {
      "title": "Max Results (number)",
      "name": "max_results",
      "type": "integer",
      "editor": "number",
      "description": "Number input example",
      "default": 100
    },
    {
      "title": "Language (select)",
      "name": "language",
      "type": "string",
      "editor": "select",
      "description": "Dropdown select example",
      "options": [
        {
          "label": "English",
          "value": "en"
        },
        {
          "label": "Chinese",
          "value": "zh"
        },
        {
          "label": "Japanese",
          "value": "ja"
        }
      ],
      "default": "en"
    },
    {
      "title": "Category (radio)",
      "name": "category",
      "type": "integer",
      "editor": "radio",
      "description": "Radio group example",
      "options": [
        {
          "label": "Hotel",
          "value": 1
        },
        {
          "label": "Restaurant",
          "value": 2
        },
        {
          "label": "Cafe",
          "value": 3
        }
      ],
      "default": 1
    },
    {
      "title": "Data Sections (checkbox)",
      "name": "data_sections",
      "type": "array",
      "editor": "checkbox",
      "description": "Checkbox set example",
      "options": [
        {
          "label": "Reviews",
          "value": "reviews"
        },
        {
          "label": "Address",
          "value": "address"
        },
        {
          "label": "Phone Number",
          "value": "phone_number"
        }
      ],
      "default": ["reviews", "address"]
    },
    {
      "title": "Skip Closed (switch)",
      "name": "skip_closed",
      "type": "boolean",
      "editor": "switch",
      "description": "Toggle switch example",
      "default": false
    },
    {
      "title": "Since Date (datepicker)",
      "name": "since_date",
      "type": "string",
      "editor": "datepicker",
      "description": "Date picker example",
      "format": "DD/MM/YYYY",
      "valueFormat": "DD/MM/YYYY"
    }
  ]
}
